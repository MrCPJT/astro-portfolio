---
interface Props {
  prevPost?: {
    slug: string;
    title: string;
  };
  nextPost?: {
    slug: string;
    title: string;
  };
  postType: "blog" | "projects";
}

const { prevPost, nextPost, postType } = Astro.props;
---

<footer class="mt-12 border-t border-[var(--color-border)] pt-6">
  <nav class="grid grid-cols-2 gap-4">
    <div
      class={`group rounded-lg p-4 transition-colors ${prevPost ? "hover:bg-[var(--color-surface-muted)]" : "cursor-not-allowed opacity-50"}`}
    >
      {
        prevPost ? (
          <a href={`/${postType}/${prevPost.slug}`} class="block">
            <div class="mb-2 flex items-center text-sm text-[var(--color-text-muted)]">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 mr-1 transition-transform group-hover:-translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 19l-7-7 7-7"
                />
              </svg>
              <span>Previous</span>
            </div>
            <div class="line-clamp-2 text-[var(--color-text-muted)] group-hover:text-[var(--color-primary)]">
              {prevPost.title}
            </div>
          </a>
        ) : (
          <div>
            <div class="mb-2 flex items-center text-sm text-[var(--color-text-muted)]">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 mr-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 19l-7-7 7-7"
                />
              </svg>
              <span>Previous</span>
            </div>
            <div class="text-[var(--color-text-muted)]">No previous post</div>
          </div>
        )
      }
    </div>
    <div
      class={`group rounded-lg p-4 transition-colors ${nextPost ? "hover:bg-[var(--color-surface-muted)]" : "cursor-not-allowed opacity-50"}`}
    >
      {
        nextPost ? (
          <a href={`/${postType}/${nextPost.slug}`} class="block text-right">
            <div class="mb-2 flex items-center justify-end text-sm text-[var(--color-text-muted)]">
              <span>Next</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 ml-1 transition-transform group-hover:translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </div>
            <div class="line-clamp-2 text-[var(--color-text-muted)] group-hover:text-[var(--color-primary)]">
              {nextPost.title}
            </div>
          </a>
        ) : (
          <div class="text-right">
            <div class="mb-2 flex items-center justify-end text-sm text-[var(--color-text-muted)]">
              <span>Next</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 ml-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </div>
            <div class="text-[var(--color-text-muted)]">No next post</div>
          </div>
        )
      }
    </div>
  </nav>
</footer>
