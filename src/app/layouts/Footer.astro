---
import { FaSolidRss, FaBrandsLinkedinIn, FaBrandsGithub } from "solid-icons/fa";

const today = new Date();
---

<footer class="mt-12 border-t border-[var(--color-border)] py-8">
  <div class="max-w-3xl mx-auto px-4">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
      <span
        class="text-center text-sm text-[var(--color-text-muted)] sm:text-left"
      >
        &copy; {today.getFullYear()} Connor Tynan. All rights reserved.
      </span>
      <div class="flex justify-center gap-4">
        <a
          href="/rss.xml"
          target="_blank"
          class="transition-transform hover:rotate-6"
          aria-label="Subscribe to RSS feed"
        >
          <FaSolidRss size={32} class="text-[var(--color-text)]" />
        </a>
        <a
          href="https://www.linkedin.com/in/your-profile"
          target="_blank"
          class="transition-transform hover:rotate-6"
          aria-label="Follow on LinkedIn"
        >
          <FaBrandsLinkedinIn size={32} class="text-[var(--color-text)]" />
        </a>
        <a
          href="https://github.com/your-username"
          target="_blank"
          class="transition-transform hover:rotate-6"
          aria-label="View GitHub profile"
        >
          <FaBrandsGithub size={32} class="text-[var(--color-text)]" />
        </a>
      </div>
    </div>
  </div>
</footer>
