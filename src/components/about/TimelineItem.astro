---
interface Props {
  title: string;
  subtitle: string;
  description?: string;
  startDate: Date;
  endDate: Date;
  endLabel?: string;
}

const { title, subtitle, description, startDate, endDate, endLabel } =
  Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en-GB", {
    month: "short",
    year: "numeric",
  }).format(date);
---

<div class="border-l-4 border-[var(--color-primary)] pl-4">
  <h3 class="text-xl font-semibold">{title}</h3>
  <p class="text-[var(--color-text-muted)]">
    {subtitle}

    <span class="ml-2">
      {formatDate(startDate)} – {endLabel ?? formatDate(endDate)}
    </span>
  </p>
  {description && <p class="mt-2">{description}</p>}
</div>
