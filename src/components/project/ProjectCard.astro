---
interface Props {
  title: string;
  technologies: string;
  summary?: string;
  link?: string;
}

const { title, technologies, summary, link } = Astro.props;
---

<div class="border-b border-[var(--color-border)] pb-4">
  <h3 class="text-xl font-semibold">{title}</h3>
  <p class="text-[var(--color-text-muted)]">Skills: {technologies}</p>
  <p class="mt-2">{summary}</p>
  {
    link && (
      <a
        href={link}
        class="group mt-2 flex items-center space-x-1.5 text-sm text-[var(--color-text-muted)] transition-colors"
      >
        <span class="hover-underline link-accent">View Details</span>
      </a>
    )
  }
</div>
