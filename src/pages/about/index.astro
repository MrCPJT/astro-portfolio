---
import Layout from "@/app/layouts/Layout.astro";
import Animation from "@/app/components/Animation.astro";
---

<Layout
  title="About | Connor Tynan"
  description="A more personal note from Connor Tynan about work, curiosity, and the person behind the portfolio."
>
  <Animation>
    <section class="space-y-8">
      <div>
        <h1 class="text-3xl font-bold text-[var(--color-text)]">About</h1>
        <p class="mt-3 text-[var(--color-text-muted)]">
          A more personal space for the parts of my story that do not fit neatly
          into a resume.
        </p>
      </div>

      <div class="surface-card space-y-4 rounded-lg border p-4">
        <p>
          I am using this page to write more directly about what I care about,
          how I think, and the kinds of work that feel meaningful to me.
        </p>
        <p>
          More soon.
        </p>
      </div>
    </section>
  </Animation>
</Layout>
