---
import Layout from "@/app/layouts/Layout.astro";
import BlogPage from "@/components/blog/BlogPage";
import { getAllBlogPosts } from "@/app/api/blog";

const posts = await getAllBlogPosts();

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<Layout
  title="Blog | Connor Tynan"
  description="Writing on data science projects, analysis workflows, notebooks, and career notes."
>
  <BlogPage posts={posts} allTags={allTags} client:load />
</Layout>
