---
import Layout from "@/app/layouts/Layout.astro";
import Animation from "@/app/components/Animation.astro";
import { getCollection } from "astro:content";
import Section from "@/components/about/Section.astro";
import TimelineItem from "@/components/about/TimelineItem.astro";
import ProjectList from "@/components/project/ProjectList.astro";
import { Tag } from "@/components/common/Tag";

const records = await getCollection("projects");
---

<Layout
  title="Resume | Connor Tynan"
  description="Resume and professional profile for Connor Tynan."
>
  <Animation>
    <section class="space-y-8">
      <div>
        <h1 class="text-3xl font-bold text-[var(--color-text)]">Resume</h1>
        <p class="mt-3 text-[var(--color-text-muted)]">
          A concise snapshot of my data science experience, technical toolkit,
          and project experience.
        </p>
      </div>

      <div class="surface-card space-y-4 rounded-lg border p-4">
        <h2 class="text-xl font-semibold">Download</h2>
        <a
          href="/resume/connor-tynan-resume.pdf"
          class="link-accent inline-block hover:underline"
        >
          Download resume PDF
        </a>
      </div>

      <Section id="education" title="Education">
        <div class="space-y-4">
          <TimelineItem
            title="Master of Mathematics (MMath), First Class Honours"
            subtitle="University of Exeter, Exeter"
            startDate={new Date("2019-09-01")}
            endDate={new Date("2023-06-30")}
            description="Completed an integrated master's degree in mathematics, graduating with First Class Honours."
          />
        </div>
      </Section>

      <Section id="skills" title="Skills">
        <div class="surface-card rounded-lg border p-4">
          <h3 class="mb-3 text-xl font-semibold">Core toolkit</h3>
          <p class="mb-2">
            A practical mix of programming, modelling, scientific computing,
            cloud tooling, and reproducible analysis.
          </p>
          <div class="mt-3 flex flex-wrap gap-2">
            {
              [
                "Python",
                "MATLAB",
                "R",
                "pandas",
                "NumPy",
                "scikit-learn",
                "seaborn",
                "matplotlib",
                "PyTorch",
                "AWS",
                "git",
                "HPC",
                "Jupyter",
                "Docker",
              ].map((tech) => <Tag>{tech}</Tag>)
            }
          </div>
          <a
            href="https://github.com/MrCPJT"
            class="link-accent mt-4 inline-block hover:underline"
            target="_blank"
            rel="noopener noreferrer">View GitHub profile</a
          >
        </div>
      </Section>

      <Section id="experience" title="Work Experience">
        <div class="space-y-4">
          <TimelineItem
            title="Higher Scientist (Data Science)"
            subtitle="National Physical Laboratory (NPL), London"
            startDate={new Date("2025-06-01")}
            endDate={new Date()}
            endLabel="Present"
            description="Developing software for statistical methods, investigating correlated stochastic processes and uncertainty estimates, and acting as technical lead on customer-facing projects."
          />
          <TimelineItem
            title="Scientist (Data Science)"
            subtitle="National Physical Laboratory (NPL), London"
            startDate={new Date("2024-03-01")}
            endDate={new Date("2025-06-30")}
            description="Built software for synthetic tabular data generation, statistical methods, and numerical analysis; contributed to work on inverse problems, hypothesis testing, trustworthy AI, and uncertainty quantification software."
          />
        </div>
      </Section>

      <Section id="projects" title="Projects">
        <ProjectList projects={records} />
      </Section>
    </section>
  </Animation>
</Layout>
