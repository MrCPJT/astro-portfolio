---
import Layout from "@/app/layouts/Layout.astro";
import Animation from "@/app/components/Animation.astro";
---

<Layout
  title="Resume | Connor Tynan"
  description="Resume and professional profile for Connor Tynan, data scientist."
>
  <Animation>
    <section class="space-y-8">
      <div>
        <h1 class="text-3xl font-bold text-[var(--color-text)]">Resume</h1>
        <p class="mt-3 text-[var(--color-text-muted)]">
          A concise snapshot of my data science experience, technical toolkit,
          selected work, and project experience.
        </p>
      </div>

      <div class="surface-card space-y-4 rounded-lg border p-4">
        <h2 class="text-xl font-semibold">Download</h2>
        <p>Download the latest version of my resume as a PDF.</p>
        <a
          href="/resume/connor-tynan-resume.pdf"
          class="link-accent inline-block hover:underline"
        >
          Download resume PDF
        </a>
      </div>

      <div class="space-y-3">
        <h2 class="text-xl font-semibold">Profile</h2>
        <p>
          Data scientist at the National Physical Laboratory with a mathematics
          background and experience in statistical methods, synthetic data
          generation, uncertainty estimation, numerical analysis, and technical
          communication.
        </p>
      </div>

      <div class="space-y-3">
        <h2 class="text-xl font-semibold">Focus areas</h2>
        <ul class="list-disc list-inside space-y-1">
          <li>Statistical modelling and uncertainty quantification</li>
          <li>Synthetic tabular data generation and numerical analysis</li>
          <li>Machine learning prototypes and reproducible workflows</li>
          <li>Scientific computing with Python, R, MATLAB, and Jupyter</li>
          <li>
            Clear technical writing, review, and stakeholder communication
          </li>
        </ul>
      </div>
    </section>
  </Animation>
</Layout>
