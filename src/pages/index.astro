---
import Layout from "@/app/layouts/Layout.astro";
import { FaSolidChartLine, FaSolidFileLines } from "solid-icons/fa";
import { getCollection } from "astro:content";
import { BlogCard } from "@/components/blog/BlogCard";
import Animation from "@/app/components/Animation.astro";

const posts = await getCollection("blog");
const recentPosts = posts
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 3);
---

<Layout
  title="Connor Tynan | Portfolio"
  description="Portfolio and writings from a data scientist."
>
  <Animation>
    <div class="flex flex-col items-start space-y-6">
      <h1 class="text-3xl font-bold text-[var(--color-text)]">Connor Tynan</h1>
      <section>
        <h2 class="text-xl text-[var(--color-text-muted)]">
          Research scientist interested in Applied AI/ML.
        </h2>

        <article class="text-base text-gray">
          <p>
            I am a data scientist with two years of experience building
            analytical workflows, machine learning models, and clear
            decision-support materials for technical and non-technical teams.
          </p>

          <p>
            This site collects some of my personal projects, writings,
            and resume.
          </p>

          <p class="flex flex-wrap gap-3 pt-3">
            <a
              href="/projects"
              class="button-secondary inline-flex items-center gap-2 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
              aria-label="View data science projects"
            >
              Projects <FaSolidChartLine size={14} /></a
            >
            <a
              href="/resume"
              class="button-primary inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-medium transition-colors"
              aria-label="View resume"
            >
              Resume <FaSolidFileLines size={14} /></a
            >
          </p>
        </article>
      </section>
    </div>

    <section>
      <div class="mt-16">
        <Animation delay={0.2}>
          <h2 class="text-2xl mb-4 text-[var(--color-text-muted)]">
            Recent Posts
          </h2>
        </Animation>
        <div class="grid grid-cols-1 gap-6">
          {
            recentPosts.map((post, index) => (
              <Animation delay={0.3 + index * 0.1}>
                <BlogCard post={post} />
              </Animation>
            ))
          }
        </div>
      </div>
    </section>
  </Animation>
</Layout>
